# Database Configuration
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_NAME=your_database_name
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database Connection URL (used by the application and migrations)
# Format: postgres://username:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://your_postgres_user:your_postgres_password@localhost:5432/your_database_name?sslmode=disable

# Application Configuration
# Note: PASETO_KEY must be exactly 32 characters long
PASETO_KEY=12345678901234567890123456789012
PORT=8080
