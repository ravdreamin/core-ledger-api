{
	"info": {
		"_postman_id": "12345678-1234-1234-1234-123456789012",
		"name": "Core Ledger API",
		"description": "FinTech API Assessment for managing financial records and calculating category-based summaries.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Login (Generate Token)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.environment.set(\"paseto_token\", jsonData.token);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"gk123456\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/login",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"login"
					]
				}
			},
			"response": []
		},
		{
			"name": "2. Get Dashboard Summary",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{paseto_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/dashboard/summary",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"dashboard",
						"summary"
					]
				}
			},
			"response": []
		},
		{
			"name": "3. Get Dashboard Categories Report",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{paseto_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/dashboard/categories",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"dashboard",
						"categories"
					]
				}
			},
			"response": []
		},
		{
			"name": "4. Create Record",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{paseto_token}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"category_id\": 2,\n    \"amount\": 850,\n    \"type\": \"expense\",\n    \"description\": \"Midnight snack run\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/records",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"records"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "paseto_token",
			"value": "",
			"type": "string"
		}
	]
}
